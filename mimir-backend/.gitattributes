# Default: Treat all text files as LF (including .sh, .java, .py, etc.)
* text eol=lf

# Override: Windows-specific files must be CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
mvnw.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.svg binary
*.pdf binary
