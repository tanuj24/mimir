ARG VERSION=latest
FROM mimir/mimir:${VERSION}

LABEL org.opencontainers.image.title="Mimir (compat)" \
      org.opencontainers.image.description="Mimir compatibility image with AWS CLI and boto3 pre-installed" \
      org.opencontainers.image.url="https://mimir.local" \
      org.opencontainers.image.source="https://github.com/mimir-local/mimir" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.vendor="Mimir"

ENV AWS_DEFAULT_REGION=us-east-1
ENV AWS_ACCESS_KEY_ID=test
ENV AWS_SECRET_ACCESS_KEY=test
ENV AWS_ENDPOINT_URL="http://localhost:4566"
ENV AWS_CONFIG_FILE=/etc/mimir/aws/config

USER root
RUN microdnf install -y --nodocs python3 python3-pip \
    && pip3 install --no-cache-dir awscli boto3 \
    && microdnf clean all \
    && rm -rf /root/.cache/pip

COPY bin/awslocal /usr/local/bin/awslocal
RUN chmod +x /usr/local/bin/awslocal

USER 1001
