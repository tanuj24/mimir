# --- Mimir backend (the bundled local AWS cloud) ---
# Endpoint the Mimir server uses to reach the backend.
BACKEND_ENDPOINT=http://localhost:4566
# Endpoint the browser can reach (used for presigned S3 URLs). Usually the same
# as BACKEND_ENDPOINT for local dev; differs under Docker Compose.
PUBLIC_BACKEND_ENDPOINT=http://localhost:4566

# Dummy credentials used to sign requests to the backend (it doesn't validate
# them, but the AWS SDK requires them to be set).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mimir
AWS_SECRET_ACCESS_KEY=mimir

# --- Mimir server ---
PORT=4000

# --- Glue local execution engine (optional overrides) ---
# Base dir for job/notebook temp dirs. Under Docker Compose this is bind-mounted
# at an identical host path so sibling containers' volume mounts resolve.
# GLUE_WORK_DIR=/tmp/mimir-glue
# Glue jobs/notebooks run on the official AWS Glue runtime images (per version).
# GLUE_IMAGE_4_0=amazon/aws-glue-libs:glue_libs_4.0.0_image_01
# GLUE_IMAGE_5_0=public.ecr.aws/glue/aws-glue-libs:5
# Endpoint the Glue containers use to reach the backend (host gateway by default).
# GLUE_AWS_ENDPOINT=http://host.docker.internal:4566
# GLUE_SESSION_IDLE_MS=7200000
# GLUE_JOB_TIMEOUT_MS=300000
