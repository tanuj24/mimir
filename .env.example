# --- Floci (the local AWS backend) ---
# Endpoint the Mimir server uses to reach Floci.
FLOCI_ENDPOINT=http://localhost:4566
# Endpoint the browser can reach (used for presigned S3 URLs). Usually the same
# as FLOCI_ENDPOINT for local dev; differs under Docker Compose.
PUBLIC_FLOCI_ENDPOINT=http://localhost:4566

# Dummy credentials used to sign requests to Floci (it doesn't validate them,
# but the AWS SDK requires them to be set).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mimir
AWS_SECRET_ACCESS_KEY=mimir

# --- Mimir server ---
PORT=4000

# --- Glue local execution engine (optional overrides) ---
# Base dir for job/notebook temp dirs. Under Docker Compose this is bind-mounted
# at an identical host path so sibling containers' volume mounts resolve.
# GLUE_WORK_DIR=/tmp/mimir-glue
# GLUE_PYTHON_IMAGE=python:3.11-slim
# GLUE_SPARK_IMAGE=spark:python3
# GLUE_JOB_TIMEOUT_MS=300000
